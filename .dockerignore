# LoomQ Docker Ignore
# Version: 0.7.0

# Build outputs
target/
*.class
*.jar
*.war
*.ear

# IDE files
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Data directories (will be mounted as volumes)
data/

# Git
.git/
.gitignore

# Documentation that's not needed in the image
*.md
docs/

# Test files
src/test/

# Local config overrides
config/application-local.yml
config/application-dev.yml

# Maven
.mvn/
mvnw
mvnw.cmd

# Scripts (can be mounted if needed)
scripts/

# Monitoring configs (optional mounting)
monitoring/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile
