# LoomQ v0.7.0 Benchmark Dockerfile
FROM eclipse-temurin:21-jdk-alpine

# 安装 wrk 压测工具和依赖
RUN apk add --no-cache wrk curl

WORKDIR /app

# 复制 jar 文件
COPY loomq-server/target/loomq-server-0.7.0-SNAPSHOT.jar /app/loomq.jar

# 暴露端口
EXPOSE 8080

# 启动命令
CMD ["java", "--enable-preview", "-jar", "loomq.jar"]
