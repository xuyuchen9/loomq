# LoomQ Environment Configuration Example
# Version: 0.7.0-SNAPSHOT
# Copy this file to .env and customize for your deployment

# =====================================================
# JVM Configuration
# =====================================================
JVM_XMS=2g
JVM_XMX=2g
JVM_GC=ZGC
JVM_GC_PAUSE=10

# =====================================================
# Server Configuration
# =====================================================
LOOMQ_SERVER_HOST=0.0.0.0
LOOMQ_SERVER_PORT=8080

# =====================================================
# WAL Configuration
# =====================================================
LOOMQ_WAL_DATA_DIR=./data/wal
LOOMQ_WAL_FLUSH_STRATEGY=batch

# =====================================================
# Scheduler Configuration
# =====================================================
LOOMQ_SCHEDULER_MAX_PENDING=1000000

# =====================================================
# Dispatcher Configuration
# =====================================================
LOOMQ_DISPATCHER_MAX_CONCURRENT=1000

# =====================================================
# Cluster Configuration (set enabled=true for cluster mode)
# =====================================================
# LOOMQ_SHARD_INDEX=0
# LOOMQ_TOTAL_SHARDS=3
# LOOMQ_NODES=shard-0:localhost:8080,shard-1:localhost:8081,shard-2:localhost:8082

# =====================================================
# Security Configuration
# =====================================================
LOOMQ_SECURITY_ENABLED=true
LOOMQ_DEV_TOKEN=dev-token-12345

# =====================================================
# Logging Configuration
# =====================================================
LOOMQ_LOG_LEVEL=INFO
LOOMQ_LOG_PATH=./logs

# =====================================================
# Extra JVM Arguments (optional)
# =====================================================
# LOOMQ_EXTRA_PROPS=-Dloomq.custom.property=value
